# Salin file ini menjadi .env lalu sesuaikan isinya

# Database SQLite — file akan dibuat otomatis di folder backend
DATABASE_URL="file:./database.db"

# JWT Secret — ganti dengan string acak yang panjang dan unik
JWT_SECRET="ganti_dengan_string_rahasia_yang_panjang"

# Port backend (default 3001)
PORT=3001
